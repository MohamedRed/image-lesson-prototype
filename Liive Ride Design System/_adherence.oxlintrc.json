{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/ride/**",
              "explorations/**",
              "ui_kits/liive-ride/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Schibsted Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Schibsted Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|ring|ringColor|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, ring, ringColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|solid|dot|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: color, solid, dot, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:neutral|accent|success|warning|danger|info)$/]",
        "message": "<Badge> color must be one of 'neutral' | 'accent' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomSheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:grabber|padding|children|key|ref|className|style|children)$/]",
        "message": "<BottomSheet> doesn't accept that prop. Declared props: grabber, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|shape|fullWidth|disabled|loading|icon|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, shape, fullWidth, disabled, loading, icon, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|capsule)$/]",
        "message": "<Button> shape must be one of 'rounded' | 'capsule'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|radius|active|raised|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, radius, active, raised, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DriverCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|rating|vehicle|plate|eta|avatarSrc|speaking|trailing|key|ref|className|style|children)$/]",
        "message": "<DriverCard> doesn't accept that prop. Declared props: name, rating, vehicle, plate, eta, avatarSrc, speaking, trailing."
      },
      {
        "selector": "JSXOpeningElement[name.name='FareRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|amount|total|muted|key|ref|className|style|children)$/]",
        "message": "<FareRow> doesn't accept that prop. Declared props: label, amount, total, muted."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:material|radius|padding|children|key|ref|className|style|children)$/]",
        "message": "<GlassPanel> doesn't accept that prop. Declared props: material, radius, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute[name.name='material'] > Literal[value!=/^(?:thin|regular|thick)$/]",
        "message": "<GlassPanel> material must be one of 'thin' | 'regular' | 'thick'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconCircle'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|filled|children|key|ref|className|style|children)$/]",
        "message": "<IconCircle> doesn't accept that prop. Declared props: color, size, filled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconCircle'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:accent|success|warning|danger|info|neutral)$/]",
        "message": "<IconCircle> color must be one of 'accent' | 'success' | 'warning' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:leading|title|subtitle|value|trailing|chevron|divider|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: leading, title, subtitle, value, trailing, chevron, divider."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|label|key|ref|className|style|children)$/]",
        "message": "<MapMarker> doesn't accept that prop. Declared props: kind, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:car|origin|destination|transfer)$/]",
        "message": "<MapMarker> kind must be one of 'car' | 'origin' | 'destination' | 'transfer'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressDots'] > JSXAttribute > JSXIdentifier[name!=/^(?:legs|current|key|ref|className|style|children)$/]",
        "message": "<ProgressDots> doesn't accept that prop. Declared props: legs, current."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingStars'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|showValue|key|ref|className|style|children)$/]",
        "message": "<RatingStars> doesn't accept that prop. Declared props: value, max, size, showValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='SOSButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|onActivate|key|ref|className|style|children)$/]",
        "message": "<SOSButton> doesn't accept that prop. Declared props: size, label, onActivate."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|onChange|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, min, max, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
